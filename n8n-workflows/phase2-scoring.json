    "Telegram Trigger":     { "main": [[{ "node": "Parse Review Command",   "type": "main", "index": 0 }]] },
    "Parse Review Command": { "main": [[{ "node": "Fetch Job Details",      "type": "main", "index": 0 }]] },
    "Fetch Job Details":    { "main": [[{ "node": "Format Review",          "type": "main", "index": 0 }]] },
    "Format Review":        { "main": [[{ "node": "Send Review",            "type": "main", "index": 0 }]] }
  },
