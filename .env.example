# ──────────────────────────────────────────────
# Cloud LLM
# ──────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ──────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated chat IDs allowed to control the bot (leave blank = no restriction)
TELEGRAM_ALLOWED_CHAT_IDS=123456789
# polling = Express app polls (standalone mode)
# n8n    = Telegram handled by n8n workflow (disable polling in Express)
TELEGRAM_MODE=polling

# ──────────────────────────────────────────────
# Application Server
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DB_PATH=./data/jobs.db

# ──────────────────────────────────────────────
# LinkedIn credentials (Phase 1+)
# ──────────────────────────────────────────────
LINKEDIN_EMAIL=your_linkedin_email@example.com
LINKEDIN_PASSWORD=your_linkedin_password_here
LINKEDIN_SEARCH_KEYWORDS=software engineer
LINKEDIN_SEARCH_LOCATION=Remote
LINKEDIN_MAX_JOBS_PER_SCAN=50

# ──────────────────────────────────────────────
# Playwright Browser (Phase 1+)
# ──────────────────────────────────────────────
PLAYWRIGHT_PROFILE_DIR=./playwright/profiles/linkedin
PLAYWRIGHT_HEADLESS=true

# ──────────────────────────────────────────────
# LLM scoring (Phase 2+)
# ──────────────────────────────────────────────
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.3
MIN_FIT_SCORE_TO_APPLY=70

# ──────────────────────────────────────────────
# Candidate Profile (feeds LLM scoring & cover letters)
# ──────────────────────────────────────────────
CANDIDATE_NAME=Your Full Name
CANDIDATE_TARGET_ROLE=Senior Software Engineer
CANDIDATE_SKILLS=Node.js,Python,AWS,Docker,PostgreSQL
CANDIDATE_EXPERIENCE_YEARS=5
CANDIDATE_LOCATION=London, UK
CANDIDATE_RESUME_PATH=

# ──────────────────────────────────────────────
# Safety / Rate limiting
# ──────────────────────────────────────────────
MAX_CONSECUTIVE_FAILURES=3
APPLY_RATE_LIMIT_PER_HOUR=5

# ──────────────────────────────────────────────
# n8n integration (if running n8n separately)
# ──────────────────────────────────────────────
N8N_WEBHOOK_BASE_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
